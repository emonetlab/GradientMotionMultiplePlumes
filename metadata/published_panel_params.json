{
  "description": "Fixed parameters and inputs for the published GradientMotionMultiplePlumes behavior regression figure panels.",
  "source": {
    "data_repository": "DANDI",
    "dandiset_id": "001871",
    "dandiset_url": "https://dandiarchive.org/dandiset/001871",
    "dandiset_api_url": "https://api.dandiarchive.org/api/dandisets/001871/",
    "development_repo": "SamuelBrudner/plumeGradMotion",
    "development_commit": "9f9730bed0eaa4a4e35dc59c518413a83e0e6dd4",
    "dandiset_version": "0.260630.1657",
    "dandiset_version_url": "https://dandiarchive.org/dandiset/001871/0.260630.1657"
  },
  "analysis_filter": {
    "timescale_ms": 200.0,
    "x_min": 30.0,
    "x_max": 220.0,
    "y_min": 67.0,
    "y_max": 97.0,
    "behavioral_filter": "facing_upwind and walking_upwind and not near_margin",
    "predictors": [
      "spatial_gradient",
      "odor_velocity",
      "signal"
    ],
    "display_note": "Gradient beta is multiplied by -1 for the cue-beta display panel.",
    "response_offset_s": 0.05,
    "margin_mm": 15.0,
    "arena_bounds_quantile": 0.01,
    "velocity_filter_cutoff_hz": 0.2,
    "velocity_filter_order": 4,
    "per_plume_filter_parameters": {
      "smooth": {
        "upwind_facing_min": 160.0,
        "upwind_facing_max": 200.0,
        "dandi_path_substrings": [
          "nagel-smoke"
        ]
      },
      "complex": {
        "upwind_facing_min": 150.0,
        "upwind_facing_max": 210.0,
        "dandi_path_substrings": [
          "smoke-2a"
        ]
      }
    }
  },
  "panels": {
    "fig5e_cue_beta": {
      "script": "scripts/plot_cue_beta_paper_panel.py",
      "smooth_table": "data/published_panel_tables/fig5e_cue_beta_smooth_plume.csv",
      "complex_table": "data/published_panel_tables/fig5e_cue_beta_complex_plume.csv",
      "output_stem": "fig5e_cue_beta",
      "fig_width": 1.7,
      "fig_height": 2.12,
      "smooth_label": "smooth",
      "complex_label": "complex",
      "smooth_title": "VR\nSmooth",
      "complex_title": "VR\nComplex",
      "y_label": "Cue \u03b2"
    },
    "fig5f_cue_dominance": {
      "script": "scripts/plot_cue_dominance_paper_panel.py",
      "smooth_table": "data/published_panel_tables/fig5f_s5_model_comparison_smooth_plume.csv",
      "complex_table": "data/published_panel_tables/fig5f_s5_model_comparison_complex_plume.csv",
      "output_stem": "fig5f_cue_dominance",
      "metric": "log_likelihood_mean",
      "fig_width": 2.4,
      "fig_height": 2.0,
      "smooth_label": "smooth",
      "complex_label": "complex",
      "smooth_display": "Smooth",
      "complex_display": "Complex",
      "title": "Cue dominance per plume",
      "y_label": "Gradient-Motion dominance",
      "y_min": -1.0,
      "y_max": 1.0
    },
    "figs5_total_differential": {
      "script": "scripts/plot_total_differential_panels.py",
      "smooth_table": "data/published_panel_tables/fig5f_s5_model_comparison_smooth_plume.csv",
      "complex_table": "data/published_panel_tables/fig5f_s5_model_comparison_complex_plume.csv",
      "output_stem": "figs5_total_differential",
      "metric": "log_likelihood_mean",
      "fig_width": 2.7,
      "fig_height": 3.0,
      "smooth_label": "smooth",
      "complex_label": "complex",
      "smooth_title": "Smooth plume",
      "complex_title": "Complex plume",
      "y_label": "Mean log-likelihood"
    }
  },
  "summary_table_generation": {
    "script": "scripts/generate_published_summary_tables.py",
    "default_output_dir": "data/generated_summary_tables",
    "raw_data_source": "DANDI NWB behavior files from dandiset 001871 version 0.260630.1657",
    "produces": [
      "fig5e_cue_beta_smooth_plume.csv",
      "fig5e_cue_beta_complex_plume.csv",
      "fig5f_s5_model_comparison_smooth_plume.csv",
      "fig5f_s5_model_comparison_complex_plume.csv"
    ]
  }
}
